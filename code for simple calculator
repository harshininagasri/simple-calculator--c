#include <stdio.h>
#include <math.h>

int main() {
    int choice;
    double num1, num2;

    printf("Simple Calculator in C\n");
    printf("Select operation:\n");
    printf("1. Add\n");
    printf("2. Subtract\n");
    printf("3. Multiply\n");
    printf("4. Divide\n");
    printf("5. Modulus (integer only)\n");
    printf("6. Power (x^y)\n");
    printf("7. Square Root\n");

    printf("Enter choice (1-7): ");
    scanf("%d", &choice);

    if (choice == 7) {
        printf("Enter number: ");
        scanf("%lf", &num1);
        if (num1 < 0) {
            printf("Error! Square root of negative number not possible.\n");
        } else {
            printf("Result: %.2lf\n", sqrt(num1));
        }
    } else {
        printf("Enter first number: ");
        scanf("%lf", &num1);
        printf("Enter second number: ");
        scanf("%lf", &num2);

        switch(choice) {
            case 1:
                printf("Result: %.2lf\n", num1 + num2);
                break;
            case 2:
                printf("Result: %.2lf\n", num1 - num2);
                break;
            case 3:
                printf("Result: %.2lf\n", num1 * num2);
                break;
            case 4:
                if(num2 == 0) {
                    printf("Error! Division by zero.\n");
                } else {
                    printf("Result: %.2lf\n", num1 / num2);
                }
                break;
            case 5:
                printf("Result: %d\n", (int)num1 % (int)num2);
                break;
            case 6:
                printf("Result: %.2lf\n", pow(num1, num2));
                break;
            default:
                printf("Invalid choice.\n");
        }
    }

    return 0;

}
